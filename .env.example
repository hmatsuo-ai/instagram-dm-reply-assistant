# =============================================================================
# 構成: GAS（LINE Messaging API） + 自営サーバ（RAG + Gemini）
#   1) python scripts/init_env.py  … INTERNAL_WEBHOOK_SECRET を自動生成
#   2) GEMINI_API_KEY を追記（Google AI Studio などで発行）
#   手順全体: SETUP.md
# =============================================================================

# GAS が Authorization: Bearer で叩く内部 API 用（GAS のスクリプトプロパティと同一）
INTERNAL_WEBHOOK_SECRET=

# GAS のみ使う場合は false（/webhook/line を無効化・露出削減）
ALLOW_DIRECT_LINE_WEBHOOK=false

# --- LINE をサーバに直接 Webhook する場合のみ（開発用。GAS 中継なら空のまま）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ALLOWED_USER_IDS=

# Gemini（設定があるとき OpenAI より優先。キーはサーバ .env のみ — GAS に書かない）
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI 互換（Gemini 未設定時のフォールバック。使わないなら空でよい）
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG（既定: output/rag_chunks.jsonl … build_rag_chunks.py の出力）
# RAG_CHUNKS_PATH=output/rag_chunks.jsonl
RAG_TOP_K=8

# サーバ（run_server.py / uvicorn が参照）
HOST=0.0.0.0
PORT=8000
