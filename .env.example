# =============================================================================
# 標準構成: LINE Webhook → このサーバ /webhook/line（GAS 不要）
#   1) python scripts/init_env.py
#   2) LINE_CHANNEL_SECRET / LINE_CHANNEL_ACCESS_TOKEN / GEMINI_API_KEY を記入
#   手順: SETUP.md / Vercel なら VERCEL_DEPLOY.md
# =============================================================================

# LINE Messaging API（LINE Developers の値を .env または Vercel の環境変数に）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ALLOWED_USER_IDS=

# true: POST /webhook/line を受ける（推奨） false: GAS などが /internal/suggest-replies のみ使う場合
ALLOW_DIRECT_LINE_WEBHOOK=true

# 任意: GAS や外部クライアントが POST /internal/suggest-replies を使うときだけ設定
INTERNAL_WEBHOOK_SECRET=

# Gemini（OpenAI より優先）
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI 互換（Gemini 未設定時のフォールバック）
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG
# RAG_CHUNKS_PATH=output/rag_chunks.jsonl
RAG_TOP_K=8

HOST=0.0.0.0
PORT=8000
