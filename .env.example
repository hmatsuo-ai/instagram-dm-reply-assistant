# --- GAS 中継（推奨）: LINE の秘密はすべて「スクリプト プロパティ」にのみ置く。
#     自営サーバには次を設定（BACKEND_SUGGEST_URL と同じ値を GAS のプロパティにも）
INTERNAL_WEBHOOK_SECRET=
# GAS のみ使う場合は false にして /webhook/line を無効化
# ALLOW_DIRECT_LINE_WEBHOOK=false

# --- LINE をサーバに直接 Webhook する場合（開発・非推奨と併用可）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# カンマ区切り。空欄のままなら全員許可（開発用・本番では必ず制限）
LINE_ALLOWED_USER_IDS=

# OpenAI 互換 API（未設定なら RAG のみ参照し定型文フォールバック）
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# RAG（既定でプロジェクトの output/rag_chunks.jsonl）
# RAG_CHUNKS_PATH=output/rag_chunks.jsonl
RAG_TOP_K=8

# サーバ
HOST=0.0.0.0
PORT=8000
